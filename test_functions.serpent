fun sayHello(name) {
    print "Hello, " + name + "!";
}

sayHello("Serpent");

fun fib(n) {
    if (n < 2) return n;
    return fib(n - 1) + fib(n - 2);
}

print "Fibonacci of 7:";
print fib(7); // Should be 13

fun add(a, b, c) {
    return a + b + c;
}

print "Adding 1, 2, 3:";
print add(1, 2, 3); // 6
